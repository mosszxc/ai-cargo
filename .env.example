# =============================================================================
# AI-Cargo Outreach Bot — Environment Variables
# Copy to .env and fill in real values before deploying
# =============================================================================

# --- Avito Parser ---
AVITO_PROXY_URL=http://user:pass@proxy-host:port
AVITO_DB_PATH=/app/data/avito_sellers.db
AVITO_MAX_PAGES=50

# --- Avito Sender ---
AVITO_ACCOUNTS_PATH=/app/data/avito_accounts.json
GOLOGIN_API_KEY=your-gologin-api-key

# --- Anthropic (message personalization + reply classification) ---
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# --- CRM: Google Sheets ---
GOOGLE_SHEETS_CREDENTIALS_FILE=/app/data/google-credentials.json
CRM_SPREADSHEET_KEY=your-google-sheets-spreadsheet-id

# --- Telegram Alerts (health-check) ---
TG_MANAGER_BOT_TOKEN=your-telegram-bot-token
TG_ALERT_CHAT_IDS=your-chat-id-1,your-chat-id-2

# --- Health-check ---
HEALTH_PORT=8080

# --- Apify (1688 product data, optional) ---
APIFY_API_TOKEN=apify_api_your-token-here
